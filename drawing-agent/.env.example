# Copy to .env and `source .env` before running. The service runs fully on the
# bundled Sample engine + offline agent with NONE of these set.

# --- Claude via AWS Bedrock (the AWS endpoint) — primary ---
export CLAUDE_CODE_USE_BEDROCK=1
export AWS_REGION=us-east-1
# Standard AWS auth — ONE of: access keys, a named profile (AWS_PROFILE), a
# Bedrock API key (AWS_BEARER_TOKEN_BEDROCK), or an IAM role when running in AWS.
export AWS_ACCESS_KEY_ID=...
export AWS_SECRET_ACCESS_KEY=...
# Bedrock model / cross-region inference profile id enabled in YOUR account,
# used for both vision detection and the agent loop. Confirm the exact id in the
# Bedrock console (it varies by account/region):
export BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-8
# Optional: private AWS gateway/proxy in front of Bedrock
# export BEDROCK_BASE_URL=https://<your-bedrock-gateway>

# --- OR Claude via Azure AI Foundry (same vars as the main app) ---
# export ANTHROPIC_FOUNDRY_ENDPOINT=https://<res>.services.ai.azure.com/anthropic/
# export ANTHROPIC_FOUNDRY_API_KEY=...
# export ANTHROPIC_FOUNDRY_DEPLOYMENT=claude-opus-4-8

# --- OR direct Anthropic (local dev) ---
# export ANTHROPIC_API_KEY=sk-ant-...
# export ANTHROPIC_MODEL=claude-opus-4-8
